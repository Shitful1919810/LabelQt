{
  "version": 6,
  "configurePresets": [
    {
      "name": "base",
      "hidden": true,
      "generator": "Ninja",
      "cacheVariables": {
        "CMAKE_EXPORT_COMPILE_COMMANDS": "ON",
        "LABELQT_ENABLE_TESTS": "ON"
      }
    },
    {
      "name": "debug-base",
      "hidden": true,
      "inherits": "base",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug"
      }
    },
    {
      "name": "release-base",
      "hidden": true,
      "inherits": "base",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release"
      }
    },
    {
      "name": "linux-debug",
      "displayName": "Linux Debug",
      "inherits": "debug-base",
      "binaryDir": "${sourceDir}/build/linux/debug",
      "condition": {
        "type": "equals",
        "lhs": "${hostSystemName}",
        "rhs": "Linux"
      }
    },
    {
      "name": "linux-release",
      "displayName": "Linux Release",
      "inherits": "release-base",
      "binaryDir": "${sourceDir}/build/linux/release",
      "condition": {
        "type": "equals",
        "lhs": "${hostSystemName}",
        "rhs": "Linux"
      }
    },
    {
      "name": "windows-debug",
      "displayName": "Windows Debug",
      "inherits": "debug-base",
      "binaryDir": "${sourceDir}/build/windows/debug",
      "condition": {
        "type": "equals",
        "lhs": "${hostSystemName}",
        "rhs": "Windows"
      }
    },
    {
      "name": "windows-release",
      "displayName": "Windows Release",
      "inherits": "release-base",
      "binaryDir": "${sourceDir}/build/windows/release",
      "condition": {
        "type": "equals",
        "lhs": "${hostSystemName}",
        "rhs": "Windows"
      }
    },
    {
      "name": "windows-static-release",
      "displayName": "Windows Static Release (Experimental)",
      "inherits": "release-base",
      "binaryDir": "${sourceDir}/build/windows/static-release",
      "cacheVariables": {
        "LABELQT_ENABLE_STATIC_QT_EXPERIMENT": "ON",
        "LABELQT_ENABLE_TESTS": "OFF"
      },
      "condition": {
        "type": "equals",
        "lhs": "${hostSystemName}",
        "rhs": "Windows"
      }
    },
    {
      "name": "windows-vs-debug",
      "displayName": "Windows Debug (Visual Studio)",
      "generator": "Visual Studio 17 2022",
      "architecture": "x64",
      "binaryDir": "${sourceDir}/build/windows-vs/debug",
      "cacheVariables": {
        "CMAKE_EXPORT_COMPILE_COMMANDS": "OFF",
        "LABELQT_ENABLE_TESTS": "ON"
      },
      "condition": {
        "type": "equals",
        "lhs": "${hostSystemName}",
        "rhs": "Windows"
      }
    },
    {
      "name": "windows-vs-release",
      "displayName": "Windows Release (Visual Studio)",
      "generator": "Visual Studio 17 2022",
      "architecture": "x64",
      "binaryDir": "${sourceDir}/build/windows-vs/release",
      "cacheVariables": {
        "CMAKE_EXPORT_COMPILE_COMMANDS": "OFF",
        "LABELQT_ENABLE_TESTS": "ON"
      },
      "condition": {
        "type": "equals",
        "lhs": "${hostSystemName}",
        "rhs": "Windows"
      }
    },
    {
      "name": "windows-vs-static-release",
      "displayName": "Windows Static Release (Visual Studio, Experimental)",
      "generator": "Visual Studio 17 2022",
      "architecture": "x64",
      "binaryDir": "${sourceDir}/build/windows-vs/static-release",
      "cacheVariables": {
        "CMAKE_EXPORT_COMPILE_COMMANDS": "OFF",
        "LABELQT_ENABLE_STATIC_QT_EXPERIMENT": "ON",
        "LABELQT_ENABLE_TESTS": "OFF"
      },
      "condition": {
        "type": "equals",
        "lhs": "${hostSystemName}",
        "rhs": "Windows"
      }
    },
    {
      "name": "macos-debug",
      "displayName": "macOS Debug",
      "inherits": "debug-base",
      "binaryDir": "${sourceDir}/build/macos/debug",
      "condition": {
        "type": "equals",
        "lhs": "${hostSystemName}",
        "rhs": "Darwin"
      }
    },
    {
      "name": "macos-release",
      "displayName": "macOS Release",
      "inherits": "release-base",
      "binaryDir": "${sourceDir}/build/macos/release",
      "condition": {
        "type": "equals",
        "lhs": "${hostSystemName}",
        "rhs": "Darwin"
      }
    }
  ],
  "buildPresets": [
    {
      "name": "linux-debug",
      "configurePreset": "linux-debug"
    },
    {
      "name": "linux-release",
      "configurePreset": "linux-release"
    },
    {
      "name": "windows-debug",
      "configurePreset": "windows-debug"
    },
    {
      "name": "windows-release",
      "configurePreset": "windows-release"
    },
    {
      "name": "windows-static-release",
      "configurePreset": "windows-static-release",
      "targets": [
        "LabelQtStatic"
      ]
    },
    {
      "name": "windows-vs-debug",
      "configurePreset": "windows-vs-debug",
      "configuration": "Debug"
    },
    {
      "name": "windows-vs-release",
      "configurePreset": "windows-vs-release",
      "configuration": "Release"
    },
    {
      "name": "windows-vs-static-release",
      "configurePreset": "windows-vs-static-release",
      "configuration": "Release",
      "targets": [
        "LabelQtStatic"
      ]
    },
    {
      "name": "macos-debug",
      "configurePreset": "macos-debug"
    },
    {
      "name": "macos-release",
      "configurePreset": "macos-release"
    }
  ],
  "testPresets": [
    {
      "name": "linux-debug",
      "configurePreset": "linux-debug",
      "output": {
        "outputOnFailure": true
      }
    },
    {
      "name": "windows-debug",
      "configurePreset": "windows-debug",
      "output": {
        "outputOnFailure": true
      }
    },
    {
      "name": "windows-vs-debug",
      "configurePreset": "windows-vs-debug",
      "configuration": "Debug",
      "output": {
        "outputOnFailure": true
      }
    },
    {
      "name": "macos-debug",
      "configurePreset": "macos-debug",
      "output": {
        "outputOnFailure": true
      }
    }
  ]
}
